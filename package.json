{
  "name": "redoubt-overview",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://devsrivas03.github.io/Redoubt-Overview/",
  "description": "Redoubt overview dashboard redesign — React + TSX consuming the Design System via Module Federation",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "webpack serve --mode development",
    "start:ds-local": "webpack serve --mode development --env scenario=ds-local",
    "start:ds-remote": "webpack serve --mode development --env scenario=ds-remote",
    "build": "webpack --mode production",
    "typecheck": "tsc --noEmit",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/hash": "0.9.2",
    "@emotion/memoize": "0.9.0",
    "@emotion/react": "11.14.0",
    "@emotion/serialize": "1.3.3",
    "@emotion/sheet": "1.4.0",
    "@emotion/styled": "11.14.1",
    "@emotion/unitless": "0.10.0",
    "@emotion/utils": "1.4.2",
    "@emotion/weak-memoize": "0.4.0",
    "@mui/material": "7.3.9",
    "@mui/private-theming": "7.3.9",
    "@mui/styled-engine": "7.3.9",
    "@mui/system": "7.3.9",
    "@mui/utils": "7.3.9",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "process": "^0.11.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-router-dom": "7.13.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@module-federation/enhanced": "^2.2.3",
    "@types/leaflet": "^1.9.21",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "css-loader": "^7.1.2",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.3",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  }
}
